{
  "name": "cocli",
  "version": "1.0.0",
  "description": "CoCli 脚手架工具",
  "type": "module",
  "private": false,
  "bin": {
    "cocli": "./apps/main/bin/cocli.js"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "turbo run release",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:all": "vitest run",
    "cocli": "node apps/main/bin/cocli.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/couriourc/cocli.git",
    "directory": "apps/main"
  },
  "dependencies": {
    "turbo": "^2.8.16"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "execa": "^8.0.0",
    "js-yaml": "^4.1.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0"
  }
}
